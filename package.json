{
  "name": "btrz-http-service",
  "version": "1.49.0",
  "description": "HTTP related utilities for Betterez APIs",
  "main": "index.js",
  "scripts": {
    "test": "NODE_ENV=test node --test --test-force-exit test/*.js",
    "test-w": "npm run tdd",
    "tdd": "NODE_ENV=test node --test --watch --test-force-exit test/*.js",
    "preversion": "npm test",
    "postversion": "git push origin master && git push --tags",
    "version": "git tag $1",
    "prepare": "git config core.hooksPath .githooks"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Betterez/btrz-http-service.git"
  },
  "keywords": [
    "request",
    "response",
    "handlers",
    "http"
  ],
  "author": "Betterez",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/Betterez/btrz-http-service/issues"
  },
  "homepage": "https://github.com/Betterez/btrz-http-service#readme",
  "dependencies": {
    "express-mung": "0.5.1",
    "jsonwebtoken": "9.0.3",
    "object-hash": "3.0.0",
    "swagger-validation": "git+ssh://github.com/Betterez/swagger-validation.git#v10.2.0"
  },
  "devDependencies": {
    "body-parser": "2.3.0",
    "btrz-auth-api-key": "5.10.0",
    "btrz-simple-dao": "4.6.0",
    "btrz-swagger-express": "git+ssh://github.com/Betterez/btrz-swagger-express.git#v3.1.0",
    "chance": "1.1.13",
    "eslint": "10.6.0",
    "eslint-config-btrz-base": "2.0.0",
    "express": "4.22.2",
    "globals": "17.7.0",
    "redis": "3.1.2",
    "supertest": "7.2.2"
  }
}
